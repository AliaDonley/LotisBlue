			Hs<-P[[k]][keep,i] * (1-P[[k]][keep,i]) + P[[k]][keep,j] * (1-P[[k]][keep,j])
			
			fstGw[x,k]<-mean(Ht-Hs)/mean(Ht)
			fst<-(Ht-Hs)/Ht
			fst90[x,k]<-quantile(fst,.9,na.rm=TRUE)
